# NarrativeLens Backend — Environment Configuration
# Copy this file to .env and fill in your values.

# Application
APP_NAME=NarrativeLens
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8080

# Logging: "json" for production, "console" for local dev
LOG_LEVEL=INFO
LOG_FORMAT=console

# Dataset
# DATA_PATH=/path/to/data.jsonl  # defaults to ../data/data.jsonl relative to this file
MAX_ROWS_IN_MEMORY=100000
